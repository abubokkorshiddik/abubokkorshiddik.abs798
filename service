html { scroll-behavior: smooth; }

body {
  margin: 0;
  font-family: "Segoe UI", Arial, sans-serif;
  background: #f8fafc;
  color: #1f2937;
}

/* NAVBAR (STICKY) */
.navbar {
  background: #020617;
  position: sticky;
  top: 0;
  z-index: 9999;
}

.nav-inner {
  max-width: 1000px;
  margin: auto;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

/* NAV LINKS */
.nav-inner a {
  color: #cbd5e1;
  margin-right: 15px;
  text-decoration: none;
  font-weight: 500;
}

.nav-inner a:hover {
  color: #60a5fa;
}

/* DROPDOWN */
.nav-inner .dropdown {
  position: relative;
}

/* ALIGN FIX */
.nav-inner .dropbtn {
  background: none;
  border: none;
  color: #cbd5e1;
  font-weight: 500;
  font-size: 17px;
  font-family: inherit;
  cursor: pointer;
  padding: 0;
  margin-right: 15px;
}

/* HOVER MATCH */
.nav-inner .dropbtn:hover {
  color: #60a5fa;
}

/* DROPDOWN FIX */
.nav-inner .dropdown-content {
  display: none;
  position: absolute;
  background-color: #0b2d5c;
  min-width: 160px;
  box-shadow: 0px 4px 8px rgba(0,0,0,0.2);
  border-radius: 6px;
  z-index: 9999;

  top: 100%;   /* FIX GAP */
  left: 0;
}

/* KEEP OPEN */
.nav-inner .dropdown:hover .dropdown-content {
  display: block;
}

/* DROPDOWN LINKS */
.nav-inner .dropdown-content a {
  color: #cbd5e1;
  padding: 8px 12px;
  text-decoration: none;
  display: block;
  font-weight: 500;
}

.nav-inner .dropdown-content a:hover {
  background-color: #1e3a8a;
  color: white;
}

/* HEADER */
.header {
  background: linear-gradient(135deg, #020617, #0b3a6e);
  color: white;
  padding: 45px 20px;
  text-align: center;
}

/* CONTAINER */
.container {
  max-width: 1000px;
  margin: auto;
  padding: 40px 20px;
}

/* CARD STYLE */
.card {
  background: white;
  padding: 18px;
  margin-bottom: 18px;
  border-left: 4px solid #1d4ed8;
  border-radius: 6px;
  line-height: 1.7;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
